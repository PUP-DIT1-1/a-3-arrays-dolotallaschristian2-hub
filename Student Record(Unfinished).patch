package com.mycompany.arraybubble;
import java.util.*;

public class A3 {
    static boolean swapped = false;
    static boolean stop = false;
    static Scanner sc = new Scanner (System.in);
    static String name[][] = {// Grades sored in Array
        { "Jex"}, {"Kiel"},{"Enzo"},{"Kyle"},{"Dwight"},{"Joseph"},{"Paul"},{"Sean"},{"Russel"},{"Chester"}};
    static int grade[][] = {
        {77, 82, 83, 79, 86, 88, 93},
        {84, 91, 72, 95, 70, 97, 81},
        {91, 76, 99, 73, 91, 83, 73},
        {83, 75, 83, 95, 74, 76, 80},
        {86, 84, 89, 91, 77, 83, 85},
        {79, 78, 79, 80, 81, 85, 86},
        {88, 87, 84, 82, 79, 80, 86},
        {91, 97, 95, 99, 94, 93, 92},
        {89, 94, 81, 88, 87, 84, 81},
        {85, 86, 78, 95, 88, 82, 84},
    };
    
    public static void Error(){ // Error Handling
        System.out.println("Invalid Parameter");
    }  
    
    public static void Info(){ //Info Display for Student and the Grade
        for(int a = 0; a < name.length; a++){
            for (int b = 0; b < name[a].length; b++){
                System.out.println(name[a][b] + " " + Arrays.toString(grade[a]));
            } 
            System.out.println();
        }
    }
     public static void printArray(int[] number){ // Printing of the Arrays
        
         Arrays.sort(grade);//sorts the grade
         for(int i = 0; i < grade.length; i++){
            System.out.println(grade[i]);
            
        }
    }
     
     public static double[] Averages(int[][] Array){ // Average of the Student Inside the Array
         double [] Average = new double[Array.length];
         
         for(int row = 0; row < Array.length; row++){
             double rowTotal = 0;
             for(int column = 0; column < Array[row].length; column++){
            rowTotal += Array[row][column];
        }
    Average[row] = rowTotal / Array[row].length; 
    } 
    return Average;
         }
     public static void GradeSheet(){
         double[] average = Averages(grade);
       for( int a = 0; a < grade.length; a++){
           System.out.println(average[a]);
       }
       
     }
     public static void main(String[] args){
         while(!stop){
         System.out.println("Welcome to the Student Record");// Main Interface
         System.out.println("1. Students and Grades");
         System.out.println("2. Averages"); 
         System.out.println("3. Grades (From Highes to Lowest)");
         System.out.println("4. Exit");
         int a = sc.nextInt();
         
             switch (a) {
                 case 1:
                     Info();
                     break;
                 case 2:
                     GradeSheet();
                     break;
                 case 3:
                     for(int i = 0; i < grade.length; i++){
                         int[] temp = grade[i].clone(); // copy grades
                         Arrays.sort(temp); // ascending
                         System.out.print(name[i][0] + " : ");
                         for(int j = temp.length - 1; j >= 0; j--){
                             System.out.print(temp[j] + " ");
                         }
                         System.out.println();
                     }                break;
                 case 4:
                     stop = true;
                     break;
                 default:
                     Error();
                     break;
             }
     
     }
}
     
}
